{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/next", "dev", "-H", "0.0.0.0", "--port", "3001"],
      "port": 3001,
      "autoPort": false,
      "env": {
        "NEXT_BUILD_DIR": ".next-preview"
      }
    },
    {
      "name": "Verify Preview",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/next", "dev", "-H", "0.0.0.0", "--port", "3002"],
      "port": 3002,
      "autoPort": false,
      "env": {
        "NEXT_BUILD_DIR": ".next-verify"
      }
    }
  ]
}
